{
  "name": "strapi-plugin-sso",
  "version": "1.0.9",
  "description": "Plug-in for single sign-on with Strapi!",
  "strapi": {
    "displayName": "Single Sign On",
    "name": "strapi-plugin-sso",
    "description": "Version 5 enables single sign-on",
    "kind": "plugin"
  },
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "lint": "NODE_OPTIONS=--experimental-strip-types eslint --flag unstable_native_nodejs_ts_config",
    "test:jest": "ENV_PATH=./playground/.env  jest --verbose --runInBand --forceExit --detectOpenHandles",
    "test:cypress": "NODE_EXTRA_CA_CERTS=data/common/certs/cacert.pem cypress run",
    "e2e:services:up": "sh scripts/isscert.dev.sh && docker compose up --build --wait",
    "e2e:services:down": "docker compose down -v --remove-orphans",
    "test:cypress:open": "cypress open",
    "playground:install": "yarn playground:yalc-add-link && cd playground && yarn install --frozen-lockfile",
    "playground:yalc-add": "cd playground && yalc add strapi-plugin-sso",
    "playground:yalc-add-link": "cd playground && yalc add --link strapi-plugin-sso",
    "playground:build": "cd playground && yarn build",
    "playground:develop": "cd playground && yarn develop",
    "playground:start": "cd playground && yarn start"
  },
  "keywords": [
    "strapi",
    "plugin",
    "oauth",
    "SSO",
    "OIDC",
    "OpenID Connect"
  ],
  "peerDependencies": {
    "@strapi/strapi": "^5.49.0",
    "react-intl": "^6.6.0"
  },
  "dependencies": {
    "@jmespath-community/jmespath": "^1.3.0",
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/utils": "^5.49.0",
    "dotenv": "^17.4.0",
    "generate-password": "^1.7.1",
    "pkce-challenge": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.0",
    "supertest": "^7.2.0"
  },
  "author": {
    "name": "yasudacloud",
    "url": "https://github.com/yasudacloud/strapi-plugin-sso"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasudacloud/strapi-plugin-sso"
  },
  "bugs": {
    "url": "https://github.com/yasudacloud/strapi-plugin-sso/issues"
  },
  "maintainers": [
    {
      "name": "yasudacloud"
    }
  ],
  "engines": {
    "node": ">=22.0.0 <=24.x.x",
    "npm": ">=8.6.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.49.0",
    "@strapi/typescript-utils": "^5.49.0",
    "@testing-library/cypress": "^10.1.0",
    "@types/cookies": "^0.9.2",
    "@types/koa": "^2.15.2",
    "@types/react": "^18.0.0",
    "accepts": "^1.3.8",
    "cypress": "^15.18.0",
    "cypress-terminal-report": "^7.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.0",
    "nock": "^14.0.5",
    "prettier": "^3.9.4",
    "react-intl": "^6.6.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.0",
    "yalc": "^1.0.0-pre.53"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".tmp",
      "dist",
      ".cache"
    ],
    "testEnvironment": "node"
  },
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  }
}
